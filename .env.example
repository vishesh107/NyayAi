# ─────────────────────────────────────────
# NyayAI Backend — Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5500

# JWT Secret — use a long random string in production
JWT_SECRET=nyayai_super_secret_jwt_key_change_this_in_production_2024
JWT_EXPIRES_IN=7d

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Razorpay
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Email (Nodemailer — use Gmail or SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=NyayAI <your@gmail.com>

# Trial settings
TRIAL_DAYS=3
FREE_QUERIES_PER_CAT=10

# Data directory (for JSON database)
DATA_DIR=./data

# ─── Supabase (replaces JSON file database) ───────────────────
# Get from: supabase.com → your project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key

# ─── Claude AI Chat Settings ───────────────────────────────────
# Per-bot model: startup uses Sonnet, all others use Haiku by default
# To force ALL bots to use Sonnet (better quality, higher cost):
# FORCE_MODEL=claude-sonnet-4-20250514

# Max messages per user per minute (default: 15)
MAX_REQUESTS_PER_MINUTE=15
